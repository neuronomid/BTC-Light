REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

DB_HOST=localhost
DB_PORT=5432
DB_NAME=btc_trader
DB_USER=postgres
DB_PASSWORD=postgres

SYMBOL=BTC-USD
TIMEFRAME=4h
YF_INTERVAL=1h
LOOKBACK_DAYS=730

MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_WEEKLY_LOSS=0.10
MAX_OPEN_POSITIONS=1
MAX_POSITION_DURATION_HOURS=24
MIN_TIME_BETWEEN_TRADES_HOURS=4
MAX_LEVERAGE=5.0
MIN_CONVICTION_TO_TRADE=70
MIN_EV_TO_TRADE=0.005

KELLY_FRACTION=0.25
LOG_LEVEL=INFO

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AGENT_MODEL_OPUS=anthropic/claude-opus-4-6
AGENT_MODEL_SONNET=anthropic/claude-sonnet-4-6

